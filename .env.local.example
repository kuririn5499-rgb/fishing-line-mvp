# Supabase
NEXT_PUBLIC_SUPABASE_URL=https://xxxx.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# LINE LIFF（customer 向け）
NEXT_PUBLIC_LIFF_ID_CUSTOMER=your-liff-id-customer

# LINE LIFF（captain / staff 向け）
NEXT_PUBLIC_LIFF_ID_CAPTAIN=your-liff-id-captain

# LINE Channel（Messaging API）
LINE_CHANNEL_ACCESS_TOKEN=your-channel-access-token
LINE_CHANNEL_SECRET=your-channel-secret

# Google Sheets
GOOGLE_SERVICE_ACCOUNT_EMAIL=your-sa@project.iam.gserviceaccount.com
GOOGLE_SERVICE_ACCOUNT_PRIVATE_KEY="-----BEGIN PRIVATE KEY-----\n...\n-----END PRIVATE KEY-----\n"
GOOGLE_SPREADSHEET_ID=your-spreadsheet-id

# 本番アカウントの slug（マルチテナント対応。dev は固定値を使用可）
ACCOUNT_SLUG=demo
